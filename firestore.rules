rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function hasRole(role) {
      return isAuthenticated() && getUserData().role == role;
    }
    
    function isTeacherOrAdmin() {
      return hasRole('teacher') || hasRole('admin');
    }

    // User profiles
    match /users/{uid} {
      allow read: if isAuthenticated();
      allow write: if isOwner(uid);
    }

    // Sessions
    match /sessions/{sessionId} {
      allow read: if isAuthenticated(); // Students need to read to validate room codes
      allow create: if isTeacherOrAdmin();
      allow update: if isTeacherOrAdmin() && resource.data.teacher_id == request.auth.uid;
      allow delete: if hasRole('admin');
    }

    // Session Events - Usually handled by server, but we can allow teachers to read their own session events
    match /session_events/{eventId} {
      allow read: if isTeacherOrAdmin() || (isAuthenticated() && resource.data.student_id == request.auth.uid);
      allow write: if false; // Only server (Admin SDK) should write events
    }
  }
}
